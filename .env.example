DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lightbase_estimation?schema=public"

# ─── Resend (transactional email) ──────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="Lightbase <noreply@lightbase.ca>"
# Internal team inbox: receives lead notifications + NDA confirmations bounce here.
INTERNAL_NOTIFY_EMAIL="hello@lightbase.ca"

# ─── Site URL (used in the verification magic link) ────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Gate (NDA acceptance + email verification) ────────────────────────────
# 32+ character random string. Used to HMAC-sign the access cookie and the
# verification magic-link token. Rotating this invalidates all existing
# cookies and pending verification links.
GATE_COOKIE_SECRET="change-me-to-a-32-plus-char-random-string"

# ─── Supabase (gate_leads + estimation_views) ──────────────────────────────
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJxxx..."

# ─── Cloudflare Turnstile (bot check on the gate form) ─────────────────────
# Site key is exposed to the browser; secret stays server-side.
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAAA..."
TURNSTILE_SECRET_KEY="0x4AAAAAAA..."

# ─── Google Maps (existing) ────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
